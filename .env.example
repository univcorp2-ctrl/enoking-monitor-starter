# Telegram通知設定（必須）
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# モニター設定（任意）
BUY_MARGIN_THRESHOLD_YEN=2000
REQUEST_TIMEOUT_SEC=15
REQUEST_INTERVAL_SEC=1.0

# 入荷監視のみ実行する場合は 1 を設定（restock_watch=true の仕入れ先だけを高頻度チェック）
RESTOCK_WATCH_ONLY=0

# 通知先（任意・どれでも可。設定したチャンネル全てに送信）
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
